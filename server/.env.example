# YTLearn — Environment Variables

# ── Required ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ytlearn?retryWrites=true&w=majority

# Gmail App Password (for OTP emails)
GMAIL_USER=your@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Optional ─────────────────────────────────────────────────────────────────
PORT=5000

# Comma-separated list of allowed frontend origins (for CORS)
# In production: https://your-render-frontend.onrender.com
# Leave blank to allow all origins (dev mode)
CLIENT_ORIGIN=
