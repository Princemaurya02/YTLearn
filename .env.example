# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Set this to your backend's deployed URL (e.g. Render / Railway / EC2).
# Leave EMPTY in local dev — Vite's proxy will forward /api to localhost:5000.
VITE_API_URL=https://your-backend-domain.com

# ── Backend (server/.env) ─────────────────────────────────────────────────────
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ytlearn?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=https://your-frontend-domain.com
